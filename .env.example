# Database
# Docker flow (`docker compose up -d`) uses localhost:5432 by default.
# Local flow (`npm run db:up`) prints its own DATABASE_URL and uses 55432 by default.
DATABASE_URL=postgres://aeria:aeria@localhost:5432/aeria

# API
API_PORT=4000
WEB_ORIGIN=http://localhost:5173

# Typesense
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
